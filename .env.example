# Copy this file to .env and fill in your values
# .env is gitignored and never committed
# Full documentation: https://docs.openclaw.ai/install/docker

# ─── Required ────────────────────────────────────────────────────────────────

# Secret token to authenticate gateway API access.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-secret

# ─── General ─────────────────────────────────────────────────────────────────

# Timezone
TZ=America/New_York

# ─── Claude Authentication ────────────────────────────────────────────────────
# Alternative to running `claude login` inside the container.
# Set ONE of these if you want headless authentication.
# CLAUDE_AI_SESSION_KEY=your-claude-session-key
# CLAUDE_WEB_SESSION_KEY=your-claude-web-session-key

# ─── OpenClaw Networking ─────────────────────────────────────────────────────

# Disable mDNS/Bonjour advertising on the local network
# OPENCLAW_DISABLE_BONJOUR=true

# Enable agent sandbox mode (1 | true | yes | on)
# OPENCLAW_SANDBOX=true

# Skip interactive onboarding on first start
# OPENCLAW_SKIP_ONBOARDING=true

# Override Docker socket path (for rootless Docker)
# OPENCLAW_DOCKER_SOCKET=/run/user/1000/docker.sock

# Extra host bind mounts (comma-separated, e.g. /host/path:/container/path)
# OPENCLAW_EXTRA_MOUNTS=

# Persist /home/node in a Docker named volume
# OPENCLAW_HOME_VOLUME=openclaw-home

# ─── OpenTelemetry (optional) ────────────────────────────────────────────────

# OTLP/HTTP collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Protocol — only http/protobuf is supported
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Service name label for telemetry
# OTEL_SERVICE_NAME=openclaw-claude

# Opt into latest experimental GenAI semantic attributes
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai

# Set to true if you already have an OTel SDK loaded to avoid a second instance
# OPENCLAW_OTEL_PRELOADED=true
