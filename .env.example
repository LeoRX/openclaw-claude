# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# OpenClaw configuration
# See https://docs.openclaw.ai for all available options

# Timezone (optional)
# TZ=America/New_York

# OpenClaw gateway token (optional, for securing the gateway)
# OPENCLAW_GATEWAY_TOKEN=your-secret-token

# Disable Bonjour/mDNS discovery (optional)
# OPENCLAW_DISABLE_BONJOUR=true

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-collector:4318
# OTEL_SERVICE_NAME=openclaw

# Claude authentication (alternative to `claude login` — set ONE of these)
# CLAUDE_AI_SESSION_KEY=your-session-key
# CLAUDE_WEB_SESSION_KEY=your-web-session-key
